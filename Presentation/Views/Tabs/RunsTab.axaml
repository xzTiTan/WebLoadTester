<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:WebLoadTester.Presentation.ViewModels"
             x:Class="WebLoadTester.Presentation.Views.Tabs.RunsTab"
             x:DataType="vm:RunsTabViewModel">
    <Grid RowDefinitions="Auto,*" RowSpacing="{DynamicResource CardSpacing}">
        <Border Grid.Row="0" Classes="section">
            <StackPanel Spacing="{DynamicResource FieldSpacing}">
                <TextBlock Text="Фильтры журнала запусков" Classes="section-title" />
                <WrapPanel Classes="wrap-gap">
                    <StackPanel Spacing="4" MinWidth="260">
                        <TextBlock Text="Поиск" Classes="muted" />
                        <TextBox Watermark="Короткий ID, название теста или модуль" Text="{Binding SearchText, Mode=TwoWay}" />
                    </StackPanel>
                    <StackPanel Spacing="4" MinWidth="220">
                        <TextBlock Text="Тип проверки" Classes="muted" />
                        <ComboBox ItemsSource="{Binding ModuleFilterOptions}" SelectedItem="{Binding SelectedModuleType, Mode=TwoWay}" />
                    </StackPanel>
                    <StackPanel Spacing="4" MinWidth="180">
                        <TextBlock Text="Статус" Classes="muted" />
                        <ComboBox ItemsSource="{Binding StatusFilterOptions}" SelectedItem="{Binding SelectedStatus, Mode=TwoWay}" />
                    </StackPanel>
                    <StackPanel Spacing="4" MinWidth="160">
                        <TextBlock Text="Период" Classes="muted" />
                        <ComboBox ItemsSource="{Binding PeriodOptions}" SelectedItem="{Binding SelectedPeriod, Mode=TwoWay}" />
                    </StackPanel>
                    <StackPanel Spacing="4" MinWidth="180">
                        <TextBlock Text="Ошибки" Classes="muted" />
                        <CheckBox Content="Показывать только с ошибками" IsChecked="{Binding OnlyWithErrors, Mode=TwoWay}" />
                    </StackPanel>
                </WrapPanel>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Classes="section">
            <Grid RowDefinitions="Auto,*,Auto" RowSpacing="12">
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="16">
                    <StackPanel Spacing="2">
                        <TextBlock Text="Журнал запусков" Classes="section-title" />
                        <TextBlock Text="Ниже показана история всех выполненных запусков по убыванию даты. Выберите строку, чтобы открыть отчёт и посмотреть краткие сведения по запуску."
                                   Classes="muted"
                                   TextWrapping="Wrap" />
                        <TextBlock Text="{Binding RunsSummaryText}" Classes="status-line" />
                    </StackPanel>

                    <StackPanel Grid.Column="1" Spacing="6" HorizontalAlignment="Right">
                        <TextBlock Text="{Binding SelectedRunDisplayId, StringFormat='Выбран запуск: {0}'}"
                                   Classes="muted"
                                   HorizontalAlignment="Right"
                                   IsVisible="{Binding HasValidSelection}" />
                        <TextBlock Text="Ничего не выбрано. Сначала кликните строку в журнале."
                                   Classes="muted"
                                   HorizontalAlignment="Right"
                                   IsVisible="{Binding HasValidSelection, Converter={StaticResource BooleanNotConverter}}" />
                        <Button Content="Обновить"
                                Classes="toolbar-button"
                                Command="{Binding RefreshCommand}"
                                HorizontalAlignment="Right" />
                    </StackPanel>
                </Grid>

                <Grid Grid.Row="1">
                    <DataGrid x:Name="RunsGrid"
                              MinHeight="320"
                              HeadersVisibility="Column"
                              CanUserSortColumns="False"
                              CanUserReorderColumns="False"
                              CanUserResizeColumns="True"
                              ItemsSource="{Binding Runs}"
                              SelectedItem="{Binding SelectedRun, Mode=TwoWay}"
                              AutoGenerateColumns="False"
                              HorizontalAlignment="Stretch"
                              VerticalAlignment="Stretch"
                              IsVisible="{Binding HasRuns}">
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Header="ID" Width="0.9*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding RunId, Converter={StaticResource RunIdShortDisplayConverter}}" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="Дата и время" Width="1.4*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding StartedAt, Converter={StaticResource RunStartedAtDisplayConverter}}" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="Сценарий" Binding="{Binding TestName}" Width="2.2*" />
                            <DataGridTextColumn Header="Тип проверки" Binding="{Binding ModuleName}" Width="1.8*" />
                            <DataGridTemplateColumn Header="Статус" Width="1.1*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Status, Converter={StaticResource RunStatusDisplayConverter}}" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="Длительность" Width="1.1*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding DurationMs, Converter={StaticResource RunDurationDisplayConverter}}" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="Ошибки" Binding="{Binding FailedItems}" Width="0.8*" />
                        </DataGrid.Columns>
                    </DataGrid>

                    <StackPanel Classes="empty-state"
                                Margin="8"
                                IsVisible="{Binding HasRuns, Converter={StaticResource BooleanNotConverter}}">
                        <TextBlock Text="Журнал запусков пока пуст" Classes="empty-title" />
                        <TextBlock Text="{Binding RunsSummaryText}" TextWrapping="Wrap" />
                        <TextBlock Text="После первого запуска здесь появятся дата, тип проверки, статус и быстрый доступ к материалам запуска."
                                   Classes="muted"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Grid>

                <Border Grid.Row="2"
                        BorderThickness="0,1,0,0"
                        BorderBrush="{DynamicResource BorderBrushNeutral}"
                        Padding="0,12,0,0">
                    <StackPanel Spacing="10">
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="16">
                            <StackPanel Spacing="2">
                                <TextBlock Text="Сведения о выбранном запуске"
                                           Classes="section-title"
                                           FontSize="15" />
                                <TextBlock Text="Сводка, параметры, ошибки и пользовательские материалы отображаются после выбора строки в журнале."
                                           Classes="muted"
                                           TextWrapping="Wrap" />
                            </StackPanel>

                            <WrapPanel Grid.Column="1"
                                       Classes="wrap-gap"
                                       HorizontalAlignment="Right"
                                       IsVisible="{Binding HasValidSelection}">
                                <Button Content="Открыть отчёт" Classes="primary toolbar-button" Command="{Binding OpenHtmlCommand}" IsEnabled="{Binding HasValidSelection}" />
                                <Button Content="JSON" Classes="toolbar-button" Command="{Binding OpenJsonCommand}" IsEnabled="{Binding HasValidSelection}" />
                                <Button Content="Папка" Classes="toolbar-button" Command="{Binding OpenRunFolderCommand}" IsEnabled="{Binding HasValidSelection}" />
                                <Button Content="Повторить" Classes="toolbar-button" Command="{Binding RepeatRunCommand}" IsEnabled="{Binding CanRepeatRun}" />
                                <Button Content="Скопировать ID" Classes="toolbar-button" Command="{Binding CopyRunIdCommand}" IsEnabled="{Binding HasValidSelection}" />
                                <Button Content="Удалить" Classes="danger toolbar-button" Command="{Binding RequestDeleteRunCommand}" IsEnabled="{Binding HasValidSelection}" />
                            </WrapPanel>
                        </Grid>

                        <TextBlock Text="{Binding RepeatRunHint}"
                                   Classes="status-line"
                                   IsVisible="{Binding HasRepeatRunHint}" />

                        <StackPanel IsVisible="{Binding HasValidSelection, Converter={StaticResource BooleanNotConverter}}">
                            <TextBlock Text="Запуск ещё не выбран. Выберите строку в журнале, чтобы увидеть краткую сводку, параметры, ошибки и пользовательские материалы."
                                       Classes="muted"
                                       TextWrapping="Wrap" />
                        </StackPanel>

                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled"
                                      MaxHeight="220"
                                      IsVisible="{Binding HasValidSelection}">
                            <StackPanel Spacing="10">
                                <WrapPanel Classes="wrap-gap">
                                    <Border Classes="badge">
                                        <TextBlock Text="{Binding SelectedRunDisplayModule, StringFormat='Проверка: {0}'}" FontSize="12" />
                                    </Border>
                                    <Border Classes="badge">
                                        <TextBlock Text="{Binding SelectedRun.Status, Converter={StaticResource RunStatusDisplayConverter}, StringFormat='Статус: {0}'}" FontSize="12" />
                                    </Border>
                                    <Border Classes="badge">
                                        <TextBlock Text="{Binding SelectedRunDisplayId, StringFormat='ID: {0}'}" FontSize="12" />
                                    </Border>
                                </WrapPanel>

                                <Grid ColumnDefinitions="1.1*,0.9*" ColumnSpacing="18">
                                    <StackPanel Spacing="8">
                                        <StackPanel Spacing="4">
                                            <TextBlock Text="Сводка" Classes="section-title" FontSize="14" />
                                            <TextBlock Text="{Binding DetailsSummary}" TextWrapping="Wrap" />
                                        </StackPanel>

                                        <StackPanel Spacing="4">
                                            <TextBlock Text="Параметры запуска" Classes="section-title" FontSize="14" />
                                            <TextBlock Text="{Binding DetailsProfile}" Classes="muted" TextWrapping="Wrap" />
                                        </StackPanel>
                                    </StackPanel>

                                    <StackPanel Grid.Column="1" Spacing="8">
                                        <StackPanel Spacing="4">
                                            <TextBlock Text="Пользовательские материалы" Classes="section-title" FontSize="14" />
                                            <ItemsControl ItemsSource="{Binding ArtifactLinks}"
                                                          IsVisible="{Binding HasArtifactLinks}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate x:DataType="vm:ArtifactLinkItem">
                                                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8" Margin="0,0,0,6">
                                                            <TextBlock Text="{Binding Name}" TextWrapping="Wrap" />
                                                            <Button Grid.Column="1"
                                                                    Content="Открыть"
                                                                    Command="{Binding $parent[ItemsControl].DataContext.OpenArtifactCommand}"
                                                                    CommandParameter="{Binding}" />
                                                        </Grid>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                            <TextBlock Text="Материалы для выбранного запуска не найдены."
                                                       Classes="muted"
                                                       TextWrapping="Wrap"
                                                       IsVisible="{Binding HasArtifactLinks, Converter={StaticResource BooleanNotConverter}}" />
                                        </StackPanel>

                                        <StackPanel Spacing="4">
                                            <TextBlock Text="Частые ошибки" Classes="section-title" FontSize="14" />
                                            <ItemsControl ItemsSource="{Binding TopErrors}"
                                                          IsVisible="{Binding HasTopErrors}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate x:DataType="vm:TopErrorItem">
                                                        <StackPanel Spacing="2" Margin="0,0,0,6">
                                                            <TextBlock Text="{Binding Message, StringFormat='• {0}'}" TextWrapping="Wrap" />
                                                            <TextBlock Text="{Binding Count, StringFormat='Повторений: {0}'}"
                                                                       Classes="muted"
                                                                       Margin="18,0,0,0" />
                                                        </StackPanel>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                            <TextBlock Text="Ошибки по выбранному запуску не зафиксированы."
                                                       Classes="muted"
                                                       TextWrapping="Wrap"
                                                       IsVisible="{Binding HasTopErrors, Converter={StaticResource BooleanNotConverter}}" />
                                        </StackPanel>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </ScrollViewer>

                        <StackPanel Spacing="8" IsVisible="{Binding IsDeleteConfirmVisible}">
                            <TextBlock Text="{Binding UserMessage}" Foreground="OrangeRed" TextWrapping="Wrap" />
                            <WrapPanel Classes="wrap-gap">
                                <Button Content="Подтвердить удаление" Command="{Binding ConfirmDeleteRunCommand}" />
                                <Button Content="Отмена" Command="{Binding CancelDeleteRunCommand}" />
                            </WrapPanel>
                        </StackPanel>

                        <TextBlock Text="{Binding UserMessage}"
                                   Classes="status-line"
                                   IsVisible="{Binding IsDeleteConfirmVisible, Converter={StaticResource BooleanNotConverter}}" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>
