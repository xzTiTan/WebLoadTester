<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:WebLoadTester.Presentation.ViewModels.SettingsViewModels"
             xmlns:rows="clr-namespace:WebLoadTester.Presentation.ViewModels.SettingsViewModels.UiTiming"
             xmlns:controls="clr-namespace:WebLoadTester.Presentation.Views.Controls"
             xmlns:core="clr-namespace:WebLoadTester.Core.Domain"
             x:Class="WebLoadTester.Presentation.Views.SettingsViews.UiTimingSettingsView"
             x:DataType="vm:UiTimingSettingsViewModel">
    <UserControl.DataTemplates>
        <DataTemplate x:DataType="rows:TimingTargetRowViewModel">
            <StackPanel Spacing="8" Margin="0,0,0,6">
                <Grid ColumnDefinitions="180,*,*" ColumnSpacing="8">
                    <StackPanel Grid.Column="0" Spacing="4">
                        <TextBlock Text="Метка профиля" Classes="field-label" />
                        <TextBox Text="{Binding Name, Mode=TwoWay}" Watermark="Например: Десктоп 1366x768" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Grid.ColumnSpan="2" Spacing="4">
                        <TextBlock Text="Адрес страницы" Classes="field-label" />
                        <TextBox Text="{Binding Url, Mode=TwoWay}" Watermark="https://пример.рф" />
                    </StackPanel>
                </Grid>

                <Grid ColumnDefinitions="180,120,120,220,*" ColumnSpacing="8">
                    <StackPanel Grid.Column="0" Spacing="4">
                        <TextBlock Text="Движок" Classes="field-label" />
                        <TextBox Text="{Binding BrowserDisplayName}" IsReadOnly="True" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Spacing="4">
                        <TextBlock Text="Ширина" Classes="field-label" />
                        <NumericUpDown Minimum="320" Maximum="3840" Value="{Binding ViewportWidth, Mode=TwoWay}" />
                    </StackPanel>
                    <StackPanel Grid.Column="2" Spacing="4">
                        <TextBlock Text="Высота" Classes="field-label" />
                        <NumericUpDown Minimum="240" Maximum="2160" Value="{Binding ViewportHeight, Mode=TwoWay}" />
                    </StackPanel>
                    <StackPanel Grid.Column="3" Spacing="4">
                        <TextBlock Text="Режим запуска" Classes="field-label" />
                        <ComboBox ItemsSource="{Binding HeadlessModeOptions}" SelectedItem="{Binding SelectedHeadlessMode, Mode=TwoWay}">
                            <ComboBox.ItemTemplate>
                                <DataTemplate x:DataType="rows:HeadlessModeChoice">
                                    <TextBlock Text="{Binding Label}" />
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </StackPanel>
                    <StackPanel Grid.Column="4" Spacing="4">
                        <TextBlock Text="User-Agent (дополнительно)" Classes="field-label" />
                        <TextBox Text="{Binding UserAgent, Mode=TwoWay}"
                                 Watermark="Например: Mozilla/5.0 ..." />
                    </StackPanel>
                </Grid>

                <TextBlock Text="{Binding BrowserDisplayHint}"
                           Classes="field-hint"
                           TextWrapping="Wrap" />
                <TextBlock Text="User-Agent можно оставить пустым, чтобы использовать стандартное значение Chromium. Headless поддерживает три режима: наследовать из профиля запуска, всегда headless или открывать окно браузера."
                           Classes="field-hint"
                           TextWrapping="Wrap" />
                <TextBlock Text="{Binding RowErrorText}" IsVisible="{Binding HasRowError}" Classes="error" />
            </StackPanel>
        </DataTemplate>
    </UserControl.DataTemplates>

    <StackPanel Spacing="16">
        <Border Classes="section">
            <StackPanel Spacing="12">
                <TextBlock Text="Профили загрузки Chromium" Classes="section-title" />
                <TextBlock Text="Каждая строка запускает страницу в отдельном профиле Chromium и показывает, как меняются тайминги navigation, DOMContentLoaded и load."
                           Classes="field-hint"
                           TextWrapping="Wrap" />
                <Border Classes="row-editor-header">
                    <StackPanel Spacing="6">
                        <Grid ColumnDefinitions="180,*,*" Classes="row-editor-header">
                            <TextBlock Grid.Column="0" Text="Метка профиля" Classes="row-editor-label" />
                            <TextBlock Grid.Column="1" Grid.ColumnSpan="2" Text="Страница" Classes="row-editor-label" />
                        </Grid>
                        <Grid ColumnDefinitions="180,120,120,220,*" Classes="row-editor-header">
                            <TextBlock Grid.Column="0" Text="Движок" Classes="row-editor-label" />
                            <TextBlock Grid.Column="1" Text="Ширина" Classes="row-editor-label" />
                            <TextBlock Grid.Column="2" Text="Высота" Classes="row-editor-label" />
                            <TextBlock Grid.Column="3" Text="Режим запуска" Classes="row-editor-label" />
                            <TextBlock Grid.Column="4" Text="User-Agent" Classes="row-editor-label" />
                        </Grid>
                    </StackPanel>
                </Border>
                <TextBlock Text="Это не полноценная проверка совместимости вёрстки и не межбраузерная матрица. Модуль помогает честно сравнить загрузку страницы в разных viewport/user-agent профилях Chromium."
                           Classes="field-hint"
                           TextWrapping="Wrap" />
                <controls:RowListEditorView DataContext="{Binding TargetsEditor}" />
            </StackPanel>
        </Border>

        <Border Classes="section">
            <StackPanel Spacing="12">
                <TextBlock Text="Общие параметры" Classes="section-title" />

                <Grid ColumnDefinitions="{StaticResource FieldRowColumns}" Classes="field-row">
                    <TextBlock Text="Событие загрузки" Classes="field-label" />
                    <ComboBox Classes="field-control" ItemsSource="{Binding WaitUntilOptions}" SelectedItem="{Binding WaitUntil, Mode=TwoWay}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate x:DataType="core:UiWaitUntil">
                                <TextBlock Text="{Binding ., Converter={StaticResource UiWaitUntilDisplayConverter}}" />
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </Grid>

                <Grid ColumnDefinitions="{StaticResource FieldRowColumns}" Classes="field-row">
                    <TextBlock Text="Таймаут, сек" Classes="field-label" />
                    <NumericUpDown Classes="field-control" Minimum="1" Maximum="300" Value="{Binding TimeoutSeconds, Mode=TwoWay}" />
                </Grid>

                <TextBlock Text="Ширина и высота задаются в пикселях. Результат показывает тайминги загрузки страницы для выбранного события ожидания, а не автоматическую оценку совместимости интерфейса."
                           Classes="field-hint"
                           TextWrapping="Wrap" />
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>
