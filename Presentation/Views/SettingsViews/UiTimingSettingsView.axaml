<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:WebLoadTester.Presentation.ViewModels.SettingsViewModels"
             xmlns:rows="clr-namespace:WebLoadTester.Presentation.ViewModels.SettingsViewModels.UiTiming"
             xmlns:controls="clr-namespace:WebLoadTester.Presentation.Views.Controls"
             xmlns:core="clr-namespace:WebLoadTester.Core.Domain"
             x:Class="WebLoadTester.Presentation.Views.SettingsViews.UiTimingSettingsView"
             x:DataType="vm:UiTimingSettingsViewModel">
    <UserControl.DataTemplates>
        <DataTemplate x:DataType="rows:TimingTargetRowViewModel">
            <StackPanel Spacing="6" Margin="0,0,0,6">
                <Grid ColumnDefinitions="160,4*" ColumnSpacing="6">
                    <TextBox Grid.Column="0" Text="{Binding Name, Mode=TwoWay}" Watermark="Профиль совместимости" />
                    <TextBox Grid.Column="1" Text="{Binding Url, Mode=TwoWay}" Watermark="https://пример.рф" />
                </Grid>
                <Grid ColumnDefinitions="160,120,120,120,*" ColumnSpacing="6">
                    <TextBox Grid.Column="0" Text="{Binding BrowserChannel, Mode=TwoWay}" Watermark="chromium" />
                    <NumericUpDown Grid.Column="1" Minimum="320" Maximum="3840" Value="{Binding ViewportWidth, Mode=TwoWay}" />
                    <NumericUpDown Grid.Column="2" Minimum="240" Maximum="2160" Value="{Binding ViewportHeight, Mode=TwoWay}" />
                    <CheckBox Grid.Column="3" IsThreeState="True" IsChecked="{Binding Headless, Mode=TwoWay}" Content="Headless (пусто = из профиля)"/>
                    <TextBox Grid.Column="4" Text="{Binding UserAgent, Mode=TwoWay}" Watermark="User-Agent (опционально)" />
                </Grid>
                <TextBlock Text="{Binding RowErrorText}" IsVisible="{Binding HasRowError}" Classes="error" />
            </StackPanel>
        </DataTemplate>
    </UserControl.DataTemplates>

    <StackPanel Spacing="16">
        <Border Classes="section">
            <StackPanel Spacing="12">
                <TextBlock Text="Профили совместимости" Classes="section-title" />
                <TextBlock Text="Каждая строка запускается отдельно и формирует запись в матрице совместимости отчёта." Classes="field-hint" />
                <Border Classes="row-editor-header">
                    <StackPanel Spacing="6">
                        <Grid ColumnDefinitions="160,4*" Classes="row-editor-header">
                            <TextBlock Grid.Column="0" Text="Профиль" Classes="row-editor-label" />
                            <TextBlock Grid.Column="1" Text="URL страницы" Classes="row-editor-label" />
                        </Grid>
                        <Grid ColumnDefinitions="160,120,120,120,*" Classes="row-editor-header">
                            <TextBlock Grid.Column="0" Text="Браузер" Classes="row-editor-label" />
                            <TextBlock Grid.Column="1" Text="Ширина" Classes="row-editor-label" />
                            <TextBlock Grid.Column="2" Text="Высота" Classes="row-editor-label" />
                            <TextBlock Grid.Column="3" Text="Headless" Classes="row-editor-label" />
                            <TextBlock Grid.Column="4" Text="User-Agent" Classes="row-editor-label" />
                        </Grid>
                    </StackPanel>
                </Border>
                <controls:RowListEditorView DataContext="{Binding TargetsEditor}" />
            </StackPanel>
        </Border>

        <Border Classes="section">
            <StackPanel Spacing="12">
                <TextBlock Text="Общие параметры" Classes="section-title" />

                <Grid ColumnDefinitions="{StaticResource FieldRowColumns}" Classes="field-row">
                    <TextBlock Text="Событие загрузки" Classes="field-label" />
                    <ComboBox Classes="field-control" ItemsSource="{Binding WaitUntilOptions}" SelectedItem="{Binding WaitUntil, Mode=TwoWay}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate x:DataType="core:UiWaitUntil">
                                <TextBlock Text="{Binding ., Converter={StaticResource UiWaitUntilDisplayConverter}}" />
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </Grid>

                <Grid ColumnDefinitions="{StaticResource FieldRowColumns}" Classes="field-row">
                    <TextBlock Text="Таймаут, сек" Classes="field-label" />
                    <NumericUpDown Classes="field-control" Minimum="1" Maximum="300" Value="{Binding TimeoutSeconds, Mode=TwoWay}" />
                </Grid>

                <TextBlock Text="Ширина и высота задаются в пикселях. Пустой User-Agent использует значение по умолчанию браузера." Classes="field-hint" />
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>
