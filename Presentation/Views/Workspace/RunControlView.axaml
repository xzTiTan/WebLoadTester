<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:WebLoadTester.Presentation.ViewModels.Workspace"
             x:Class="WebLoadTester.Presentation.Views.Workspace.RunControlView"
             x:DataType="vm:RunControlViewModel">
    <StackPanel Spacing="6">
        <TextBlock Text="Управление запуском" Classes="section-title" />
        <TextBlock Text="Запустите тест, наблюдайте статус и сразу откройте результаты после завершения." Classes="field-hint" TextWrapping="Wrap" />
        <StackPanel Spacing="6">
            <WrapPanel Orientation="Horizontal">
                <Button x:Name="StartButton" Content="Старт" TabIndex="0" Command="{Binding StartCommand}" IsEnabled="{Binding CanStart}" Margin="0,0,6,0" />
                <Button Content="Стоп" Command="{Binding StopCommand}" IsEnabled="{Binding CanStop}" TabIndex="1" Margin="0,0,6,0" />
                <Button Content="Перейти в прогоны" Command="{Binding OpenRunsTabCommand}" TabIndex="2" />
            </WrapPanel>

            <TextBlock Text="{Binding RunStateLabel, StringFormat=Состояние: {0}}" FontSize="15" />
            <TextBlock Text="{Binding StatusText}" Classes="muted" />
            <TextBlock Text="{Binding ProgressDetails}" Classes="muted" />
            <TextBlock Text="{Binding StageDetails}" Classes="muted" />
            <TextBlock Text="{Binding RunIdLine}" Classes="muted" />
            <TextBlock Text="{Binding FinishedAtLine}" Classes="muted" />
            <TextBlock Text="{Binding LastRunInfo}" Classes="muted" />
            <ProgressBar Minimum="0" Maximum="100" Value="{Binding ProgressValue}" IsIndeterminate="{Binding IsIndeterminate}" />

            <Border Classes="section" IsVisible="{Binding UsesPlaywrightChromium}">
                <StackPanel Spacing="4">
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                        <StackPanel Spacing="2">
                            <TextBlock Text="Playwright Chromium" Classes="field-label" />
                            <TextBlock Text="{Binding PlaywrightBrowserPathLine}"
                                       Classes="muted"
                                       TextWrapping="NoWrap"
                                       TextTrimming="CharacterEllipsis" />
                        </StackPanel>

                        <Button Content="Установить Playwright Chromium"
                                Command="{Binding InstallChromiumCommand}"
                                IsEnabled="{Binding CanInstallChromium}"
                                IsVisible="{Binding ShowInstallPlaywrightButton}" />
                    </Grid>
                    <TextBlock Text="UI-модули используют Playwright Chromium из активного каталога браузеров, а не системный браузер."
                               TextWrapping="Wrap"
                               IsVisible="{Binding IsPlaywrightStatusMissing}" />
                    <TextBlock Text="{Binding PlaywrightBrowserPathLine}"
                               Classes="muted"
                               IsVisible="False" />
                    <TextBlock Text="{Binding PlaywrightBrowserStatusLine}"
                               Classes="muted"
                               TextWrapping="Wrap"
                               IsVisible="{Binding IsPlaywrightStatusOk}" />
                    <TextBlock Text="{Binding PlaywrightBrowserStatusLine}"
                               Classes="field-hint"
                               TextWrapping="Wrap"
                               IsVisible="{Binding IsPlaywrightStatusInstalling}" />
                    <TextBlock Text="{Binding PlaywrightBrowserStatusLine}"
                               Classes="error"
                               TextWrapping="Wrap"
                               IsVisible="{Binding IsPlaywrightStatusMissing}" />
                    <TextBlock Text="{Binding PlaywrightInstallResultLine}"
                               Classes="muted"
                               TextWrapping="Wrap"
                               IsVisible="{Binding IsPlaywrightInstallResultSuccess}" />
                    <TextBlock Text="{Binding PlaywrightInstallResultLine}"
                               Classes="error"
                               TextWrapping="Wrap"
                               IsVisible="{Binding IsPlaywrightInstallResultError}" />
                    <TextBlock Text="{Binding PlaywrightLegacyNote}"
                               Classes="muted"
                               TextWrapping="Wrap"
                               IsVisible="{Binding HasPlaywrightLegacyNote}" />
                    <Button Content="Установить Playwright Chromium"
                            Command="{Binding InstallChromiumCommand}"
                            IsEnabled="{Binding CanInstallChromium}"
                            IsVisible="False" />
                </StackPanel>
            </Border>

            <ItemsControl ItemsSource="{Binding ValidationErrors}" IsVisible="{Binding HasValidationErrors}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding}" TextWrapping="Wrap" Classes="error" />
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <Button Content="Установить Chromium"
                    Command="{Binding InstallChromiumCommand}"
                    IsEnabled="{Binding CanInstallChromium}"
                    IsVisible="False" />

            <WrapPanel Orientation="Horizontal">
                <Button Content="Открыть папку прогона" Command="{Binding OpenRunFolderCommand}" IsEnabled="{Binding HasRunFolder}" Margin="0,0,6,0" TabIndex="10" />
                <Button Content="Открыть HTML" Command="{Binding OpenHtmlReportCommand}" IsEnabled="{Binding HasHtmlReport}" Margin="0,0,6,0" TabIndex="11" />
                <Button Content="Открыть JSON" Command="{Binding OpenJsonReportCommand}" IsEnabled="{Binding HasJsonReport}" TabIndex="12" />
            </WrapPanel>
            <TextBlock Text="После завершения здесь появятся быстрые действия для открытия результатов." IsVisible="{Binding HasRunFolder, Converter={StaticResource BooleanNotConverter}}" />
        </StackPanel>
    </StackPanel>
</UserControl>
